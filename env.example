# Copy this file to .env and fill in your values
# Never commit .env to git

# OpenAI API key — used in Phase 3 for LLM alignment verification
# Required only for borderline scores (0.35–0.65); pipeline works without it but confidence degrades
OPENAI_API_KEY=sk-...

# GitHub Personal Access Token — used in Phase 1 for repo metadata (size, stars)
# Without this: 60 requests/hour (unauthenticated). With this: 5,000 requests/hour.
# Create at: https://github.com/settings/tokens (no special scopes needed, public repos only)
GITHUB_TOKEN=ghp_...
